# ============================================================
# Wax | Wane — GitHub Repository Secrets Reference
# ============================================================
# Add each of these as a Repository Secret in:
# GitHub → wax-wane/wax-wane-digital-vault → Settings → Secrets and variables → Actions → New repository secret
#
# STATUS KEY:
#   ACTIVE   = Known working as of June 2026
#   REFRESH  = May need refreshing (OAuth tokens expire)
#   UNKNOWN  = Token exists but not recently verified
#   MISSING  = Not yet configured
#
# REAL VALUES: Stored in config-vault/secrets/waxwane_credentials.env on Google Drive
# ============================================================

# --- SHOPIFY ---
WAX_WANE_SHOPIFY_TOKEN=shpat_REPLACE_ME         # ACTIVE - Admin API token
WAX_WANE_SHOPIFY_STORE=6f97d0.myshopify.com     # ACTIVE - Store domain (not secret)
WAX_WANE_SHOPIFY_API_KEY=REPLACE_ME             # ACTIVE
WAX_WANE_SHOPIFY_API_SECRET=REPLACE_ME          # ACTIVE

# --- AI / CONTENT ---
OPENAI_API_KEY=sk-REPLACE_ME                    # ACTIVE - GPT-4o enrichment
PERPLEXITY_API_KEY=pplx-REPLACE_ME              # ACTIVE - Blog research
GEMINI_API_KEY=REPLACE_ME                       # ACTIVE - Crystal verbiage

# --- SOCIAL MEDIA ---
FACEBOOK_PAGE_ID=203171376205580                # ACTIVE (not a secret, just an ID)
FACEBOOK_ACCESS_TOKEN=REPLACE_ME               # REFRESH - Long-lived page token
FACEBOOK_CATALOG_ID=1162102955270557            # ACTIVE (not a secret)
FACEBOOK_COMMERCE_ACCOUNT_ID=708744235470501    # ACTIVE (not a secret)

# --- TIKTOK ---
TIKTOK_APP_KEY=REPLACE_ME                       # ACTIVE
TIKTOK_APP_SECRET=REPLACE_ME                    # ACTIVE
TIKTOK_APP_ID=7618493139276334862               # ACTIVE (not a secret)
TIKTOK_ACCESS_TOKEN=REPLACE_ME                  # REFRESH - Short-lived, needs OAuth

# --- VEEQO (Multi-channel sync) ---
VEEQO_API_KEY=REPLACE_ME                        # UNKNOWN - Check Veeqo dashboard
# Veeqo Channel IDs (not secrets, hardcode in scripts):
# Walmart: 1009103 | TikTok: 1044457 | Amazon: 1049861 | Etsy: 1049903

# --- PINTEREST ---
PINTEREST_ACCESS_TOKEN=REPLACE_ME               # REFRESH monthly (pina_... format)
PINTEREST_APP_SECRET=REPLACE_ME                 # ACTIVE

# --- TELEGRAM BOT ---
TELEGRAM_BOT_TOKEN=REPLACE_ME                   # ACTIVE - @Updatednewsstreambot
TELEGRAM_BOT_ID=7914910272                      # ACTIVE (not a secret)

# --- N8N (local Docker) ---
N8N_INSTANCE_URL=http://localhost:5678          # ACTIVE - local MacBook
N8N_MCP_JWT=REPLACE_ME                          # REFRESH - Regenerate in n8n UI

# --- GOOGLE ---
GOOGLE_OAUTH_TOKEN=REPLACE_ME                   # REFRESH - Sheets + Gmail
# Full google/token.json stored in config-vault/secrets/google/ on Google Drive

# --- WALMART ---
WALMART_CLIENT_ID=REPLACE_ME                    # UNKNOWN
WALMART_CLIENT_SECRET=REPLACE_ME               # UNKNOWN

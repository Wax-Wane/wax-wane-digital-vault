    {
      "id": "soc-find",
      "name": "Find New RSS Article",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -540,
        0
      ],
      "parameters": {
        "jsCode": "\nconst atom = $input.first().json.data || '';\nconst staticData = $getWorkflowStaticData('global');\nstaticData.postedLinks = staticData.postedLinks || {};\nconst posted = staticData.postedLinks;\n\nfunction parseAtom(xml) {\n  const entries = [];\n  const blocks = xml.split('<entry>').slice(1);\n  for (const block of blocks) {\n    const link = (block.match(/<link[^>]+href=\"([^\"]+)\"/) || [])[1];\n    const title = (block.match(/<title[^>]*>([\\s\\S]*?)<\\/title>/) || [])[1]?.replace(/<!\\[CDATA\\[|\\]\\]>/g, '').trim();\n    const summary = (block.match(/<summary[^>]*>([\\s\\S]*?)<\\/summary>/) || [])[1]?.replace(/<!\\[CDATA\\[|\\]\\]>/g, '').replace(/<[^>]+>/g, ' ').trim() || '';\n    const published = (block.match(/<published>([\\s\\S]*?)<\\/published>/) || [])[1]?.trim() || '';\n    if (link && title) entries.push({ link, title, summary, published });\n  }\n  return entries;\n}\n\nconst entries = parseAtom(atom);\nfor (const e of entries) {\n  if (posted[e.link]) continue;\n  const handle = e.link.split('/').filter(Boolean).pop();\n  return [{ json: { ...e, handle, blog_id: '119979376952', blog_name: 'Wax | Wane Blog' } }];\n}\nreturn [{ json: { skip: true, message: 'No new published articles in RSS' } }];\n"
      }
    },
    {
      "id": "soc-if-new",
      "name": "Has New Article?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        -320,
        0
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "leftValue": "={{ $json.skip }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "notEquals"
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "soc-verify",
      "name": "Verify Source-Blog Tag",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -100,
        0
      ],
      "parameters": {
        "jsCode": "\nconst cfg = $('Set Social Config').first().json;\nconst art = $('Find New RSS Article').first().json;\nif (art.skip) return [{ json: { skip: true } }];\nconst handle = art.handle;\nconst url = `https://6f97d0.myshopify.com/admin/api/2025-01/blogs/119979376952/articles.json?handle=${handle}&fields=id,handle,tags,title,image`;\nconst resp = await this.helpers.httpRequest({\n  method: 'GET', url,\n  headers: { 'X-Shopify-Access-Token': cfg.shopifyToken },\n  json: true,\n});\nconst article = (resp.articles || [])[0];\nif (!article) throw new Error('Shopify article not found for handle: ' + handle);\nconst tags = (article.tags || '').toLowerCase();\nif (!tags.includes('source-blog')) {\n  return [{ json: { skip: true, message: 'Not a with-source article (missing source-blog tag)', handle } }];\n}\nreturn [{ json: { ...art, articleId: article.id, shopifyTags: article.tags, image_url: article.image?.src || null } }];\n"
      }
    },
    {
      "id": "soc-if-source",
      "name": "Is With-Source?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        120,
        0
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "leftValue": "={{ $json.skip }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "notEquals"
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "soc-og",
      "name": "Fetch Featured Image",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        340,
        0
      ],
      "parameters": {
        "jsCode": "\nconst art = $input.first().json;\nif (art.skip) return [{ json: art }];\nif (art.image_url) return [{ json: art }];\ntry {\n  const html = await this.helpers.httpRequest({ method: 'GET', url: art.link, returnFullResponse: false });\n  const m = String(html).match(/<meta\\s+property=[\"']og:image[\"']\\s+content=[\"']([^\"']+)[\"']/i);\n  if (m) art.image_url = m[1];\n} catch (e) { /* non-fatal */ }\nreturn [{ json: art }];\n"
      }
    },
    {
      "id": "soc-cap",
      "name": "Build Platform Captions",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        560,
        0
      ],
      "parameters": {
        "jsCode": "\nconst art = $input.first().json;\nif (art.skip) return [{ json: art }];\nconst summary = (art.summary || '').replace(/<[^>]+>/g, ' ').replace(/\\s+/g, ' ').trim();\nconst pinterestHashtags = '#WellnessLifestyle #SelfCare #BeautyRitual #WaxAndWane #SlowLiving';\nconst fbCaption = `${art.title}\\n\\n${summary.substring(0, 200)}...\\n\\nRead more: ${art.link}`;\nconst igCaption = `${art.title}\\n\\n${summary.substring(0, 100)}...\\n\\nLink in bio! \ud83d\udd17`;\nconst pinDescription = (`${art.title}\\n\\n${summary.substring(0, 200)}\\n\\n${pinterestHashtags}`).substring(0, 500);\nconst linkedinCaption = `${art.title}\\n\\nWax | Wane is a modern wellness brand at the intersection of crystal science, clean Korean beauty, and EMF protection.\\n\\n${art.link}\\n\\n#WellnessBrand #Ecommerce #WaxAndWane`;\nreturn [{ json: { ...art, fbCaption, igCaption, pinDescription, linkedinCaption, pinterestHashtags } }];\n"
      }

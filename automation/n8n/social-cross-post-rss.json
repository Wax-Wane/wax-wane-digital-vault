      ],
      "parameters": {
        "jsCode": "\nconst art = $('Build Platform Captions').first().json;\nif (art.skip) return [{ json: art }];\nconst staticData = $getWorkflowStaticData('global');\nstaticData.postedLinks = staticData.postedLinks || {};\nstaticData.postedLinks[art.link] = { at: new Date().toISOString(), title: art.title };\nreturn [{ json: { status: 'cross_posted', title: art.title, url: art.link, finishedAt: new Date().toISOString() } }];\n"
      }

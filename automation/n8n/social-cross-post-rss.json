    {
      "id": "soc-rss",
      "name": "Fetch Wax Wane Blog RSS",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -760,
        0
      ],
      "parameters": {
        "method": "GET",
        "url": "https://waxandwane.store/blogs/wax-wane-blog.atom",
        "options": {
          "response": {
            "response": {

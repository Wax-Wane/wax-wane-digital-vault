      "parameters": {
        "jsCode": "const shopifyResponse = $input.first().json;\nconst article = shopifyResponse.article;\nconst blogData = $('Format Blog & Caption').first().json;\nif (!article?.id) throw new Error('Shopify failed: ' + JSON.stringify(shopifyResponse));\nconst articleUrl = `https://www.waxandwane.store/blogs/wax-wane-blog/${article.handle}`;\nconst adminUrl = `https://admin.shopify.com/store/6f97d0/articles/${article.id}`;\nreturn [{ json: { articleId: article.id, title: article.title, handle: article.handle, articleUrl, adminUrl, body_html: blogData.body_html, caption: blogData.caption, sourceUrl: blogData.sourceUrl, keywords: blogData.keywords, rowIndex: blogData.rowIndex, metaDescription: blogData.metaDescription } }];"
      }

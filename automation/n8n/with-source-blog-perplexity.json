      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const findRow = $('Find Next Source Row').first().json;\nlet text = '';\nif ((findRow.sourceContent || '').length >= 200) {\n  text = findRow.sourceContent.replace(/\\s+/g, ' ').trim().substring(0, 3000);\n} else {\n  const html = $input.first().json.data || '';\n  text = html.replace(/<script[^>]*>[\\s\\S]*?<\\/script>/gi,'').replace(/<style[^>]*>[\\s\\S]*?<\\/style>/gi,'')\n    .replace(/<[^>]+>/g,' ').replace(/\\s+/g,' ').trim().substring(0, 3000);\n}\nreturn [{ json: { extractedText: text, sourceUrl: findRow.sourceUrl, topic: findRow.topic, keywords: findRow.keywords, title: findRow.topic } }];"
      },

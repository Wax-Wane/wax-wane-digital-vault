        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"sonar\",\n  \"messages\": [\n    {\"role\":\"system\",\"content\":\"Write Wax | Wane editorial wellness blog (Clinical Glow). Semantic HTML with <h1>. No hype or emojis.\"},\n    {\"role\":\"user\",\"content\":\"Topic: {{ $json.topic }}. Keywords: {{ $json.keywords }}.\\n\\nSource material:\\n\\n{{ $json.extractedText.replace(/\\\\/g, '\\\\\\\\').replace(/\\\"/g, '\\\\\\\"').replace(/\\n/g, '\\\\n') }}\\n\\nSource: {{ $json.sourceUrl }}\"}\n  ]\n}",
        "options": {}
      },
      "id": "9ff08b01-f2d2-4012-aad9-f384457bf65e",
      "name": "Perplexity AI Writer",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -304,
        -144
      ]
    },
    {
      "parameters": {
        "jsCode": "const pplx = $input.first().json;\nlet blogHtml = pplx.choices[0].message.content;\nblogHtml = blogHtml.replace(/^```html\\s*/i,'').replace(/^```\\s*/i,'').replace(/\\s*```$/i,'').trim();\nconst findRow = $('Find Next Source Row').first().json;\nconst titleMatch = blogHtml.match(/<h1[^>]*>(.*?)<\\/h1>/i);\nconst title = titleMatch ? titleMatch[1].replace(/<[^>]+>/g,'').trim() : (findRow.title || findRow.topic);\nconst handle = title.toLowerCase().replace(/[^a-z0-9\\s-]/g,'').replace(/\\s+/g,'-').replace(/^-+|-+$/g,'').substring(0,60);\nconst stripped = blogHtml.replace(/<[^>]+>/g,' ').replace(/\\s+/g,' ').trim();\nreturn [{ json: { title, handle, body_html: blogHtml, metaDescription: stripped.substring(0,160), keywords: findRow.keywords || findRow.topic, sourceUrl: findRow.sourceUrl || findRow.docUrl, rowIndex: findRow.rowIndex, caption: `New on the Wax & Wane blog: \"${title}\"\\n\\nwaxandwane.store/blogs/wax-wane-blog/${handle}` } }];"
      },

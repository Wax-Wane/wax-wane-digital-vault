    {
      "parameters": {
        "jsCode": "function parseCsvLine(line) {\n  const vals = []; let inQuote = false, cur = '';\n  for (const ch of line) {\n    if (ch === '\"') inQuote = !inQuote;\n    else if (ch === ',' && !inQuote) { vals.push(cur.trim()); cur = ''; }\n    else cur += ch;\n  }\n  vals.push(cur.trim()); return vals;\n}\nconst raw = $input.first().json.data || '';\nconst lines = raw.split('\\n').filter(l => l.trim());\nconst rows = lines.slice(1).map(parseCsvLine);\nfunction isDone(s) {\n  s = (s || '').toLowerCase().trim();\n  if (!s) return false;\n  return ['done:', 'drafted', 'published', 'done', 'processing', 'shopify'].some(m => s === m || s.startsWith(m));\n}\nfunction topicFromUrl(url) {\n  try {\n    const slug = new URL(url).pathname.split('/').filter(Boolean).pop() || 'wellness';\n    return slug.replace(/[-_]+/g, ' ').trim();\n  } catch { return 'wellness research'; }\n}\nfor (let i = 0; i < rows.length; i++) {\n  const row = rows[i];\n  const sourceUrl = (row[0] || '').trim();\n  const sourceContent = (row[1] || '').trim();\n  const status = (row[2] || '').trim();\n  if (!sourceUrl.startsWith('http')) continue;\n  if (isDone(status)) continue;\n  const topic = topicFromUrl(sourceUrl);\n  return [{ json: { rowIndex: i + 2, sourceUrl, sourceContent, topic, keywords: topic, pipeline: 'url-source' } }];\n}\nreturn [{ json: { rowIndex: -1, message: 'No pending URL rows' } }];"
      },
